<script>
  var _url = window.location.href;
  var _lang = "";
  var _required = "";
  var _success = "";
  var _error = "";
  var _loading = "";
  var _min3carac = "";
  var _min4carac = "";
  var _valid_email = "";
  var _1dig = "";
  var _9dig = "";
  var _valid_age = "";
  var _sex_m = "";
  var _sex_f = "";

  var _valid_onenumber = "";
  if (_url.indexOf("/pt/") != -1) {
    _lang = "PT";
    _required = "Campo Obrigatório";
    _success = "Obrigado<br/><br/>A sua mensagem foi enviada com sucesso";
    _error = "Ocorreu um erro. Por favor, tente mais tarde.";
    _loading = "Aguarde um momento...";
    _min3carac = "No minimo 3 caracteres";
    _min4carac = "No minimo 4 caracteres";
    _valid_email = "Insira um email válido";
    _1dig = "Insira 1 dígito";
    _9dig = "Insira 9 dígitos";
    _valid_onenumber = "Insira um número válido";
    _valid_age = "Insira idade válida";
    _sex_m = "Masculino";
    _sex_f = "Feminino";
    _pp = "Deve aceitar a política de privacidade";
  }
  else if (_url.indexOf("/en/") != -1) {
    _lang = "EN";
    _required = "Required Field";
    _success = "Thank you <br/> <br/> Your message was sent successfully.";
    _error = "An error occurred. Please try again later.";
    _loading = "Wait a moment...";
    _min3carac = "At least 3 characters";
    _min4carac = "At least 4 characters";
    _valid_email = "Please enter a valid email address";
    _1dig = "Enter 1 digits";
    _9dig = "Enter 9 digits";
    _valid_onenumber = "Please enter a valid number";
    _valid_age = "Please enter valid age";
    _sex_m = "Male";
    _sex_f = "Female";
    _pp = "You must accept the privacy policy";
  }
  else if (_url.indexOf("/es/") != -1) {
    _lang = "ES";
    _required = "Campo Obrigatorio";
    _success = "Gracias <br/> Su mensaje ha sido enviado con éxito";
    _error = "Ocurrio un error. Por favor, intente más tarde.";
    _loading = "Espera un momento...";
    _min3carac = "Al menos 3 caracteres";
    _min4carac = "Al menos 4 caracteres";
    _valid_email = "Introduzca un correo electrónico válido";
    _1dig = "Introduzca  1 dígito";
    _9dig = "Introduzca 9 dígitos";
    _valid_onenumber = "Introduzca un número válido";
    _valid_age = "Insiradade válida";
    _sex_m = "Masculina";
    _sex_f = "Femenino";
    _pp = "Debe aceptar la política de privacidad";
  }

  $(document).ready(function () {
    $(".modalBt").click(function () {
      $("#OtherContents_container").html("");
      if ($(this).data('target') == "#modalForm") {
          $("#hidFormID").val($(this).data('src'));
      } else {
          var str = $(this).data("id");
          var ret = str.split(";");

          var vID = 0;
          if (ret[0] != undefined)
              vID = ret[0];

          var vId_Multilanguage = 1;
          if (ret[1] != undefined)
              vId_Multilanguage = ret[1];

          var vURL = 'https://palaciodogelo.pt/hdata.php?pOpc=N&pId_Multilanguage=' + vId_Multilanguage + '&pId=' + vID;

          $.ajax({
              type: 'POST',
              contentType: 'application/json; charset=utf-8',
              dataType: 'html',
              url: vURL,
              success: function (response) {
                  $("#OtherContents_container").html(response);
              },
              error: function (jqXHR, textStatus, errorThrown) {
                  console.log(textStatus, errorThrown);
              }
          });
      }
      /*ga('set', 'page','/' + $(this).data('url'));*/
    });

    $(".modalLojas").click(function () {

      var _hash = document.URL.substr(document.URL.indexOf('#') + 1);
      var _url = window.location.href;

      var str = $(this).data("id");
      var ret = str.split(";");

      var vID = 0;
      if (ret[0] != undefined)
          vID = ret[0];

      var vId_Multilanguage = 1;
      if (ret[1] != undefined)
          vId_Multilanguage = ret[1];

      var vURL = 'https://palaciodogelo.pt/hdata.php?pOpc=S&pId_Multilanguage=' + vId_Multilanguage + '&pId=' + vID;
      var vURLHash = '';

      $.ajax({
        type: 'POST',
        contentType: 'application/json; charset=utf-8',
        dataType: 'html',
        url: vURL,
        success: function (response) {
            var ArrResponse = response.split("|");
            $("#Shops_container").html(ArrResponse[0]);
            if (ArrResponse[1] != undefined)
                vURLHash = ArrResponse[1];

            window.location.hash = vURLHash;
        },
        error: function (jqXHR, textStatus, errorThrown) {
            console.log(textStatus, errorThrown);
        }
      });
      /*ga('set', 'page', '/' + $(this).data('url') + vURLHash);*/
    });
  });

  $(document).on('click', '#btPedidoInformacao', function (e) {
    e.preventDefault();
    var form = $("#formPedidoInfo");
    form.validate({
      rules:
      {
        pedido_info_name: {
          required: true,
          notPlaceholder: true
        },
        pedido_info_email: {
          required: true,
          notPlaceholder: true,
          email: true
        },
        pedido_info_contacto: {
          required: true,
          number: true
        },
        pedido_info_mensagem: {
          required: true,
          notPlaceholder: true
        }
      },
      messages:
      {
        pedido_info_name: {
          required: _required,
          notPlaceholder: _required,
          minlength:  _min3carac
        },
        pedido_info_email: {
          required: _required,
          email: _valid_email
        },
        pedido_info_contacto: {
          required: _required,
          minlength: _9dig,
          number: _valid_onenumber
        },
        pedido_info_mensagem: {
          required: _required,
          notPlaceholder: _required
        }
      }
    });

    if (form.valid()) {

      $(".lMsg").html("<center>" + _loading + "<br/><br/><img src='../images/ajax-loader.gif' alt='" + _loading + "' style='width: 128px; height: 15px;' /></center>");

      var _data = "?id=formPedidoInfo&vSubject=Pedido de Informação&vName=" + $('#pedido_info_name').val() + "&vEmail=" + $('#pedido_info_email').val() + "&vContact=" + $('#pedido_info_contacto').val() + "&vSearchInfo=" + $('#pedido_info_procuraInfo').val() + "&vMessage=" + $('#pedido_info_mensagem').val() + "&vId_Multilanguage=1";

      var settings = {
		  'data': _data,        
          'url': 'https://palaciodogelo.pt/hmail.php' + _data,
          'contentType': 'application/json; charset=utf-8'
      };

      if (sendEmail(settings) == true) {
          $(".lMsg").html(_success);
          $('#pedido_info_name').val('');
          $('#pedido_info_email').val('');
          $('#pedido_info_contacto').val('');
          $('#pedido_info_procuraInfo').val('');
          $('#pedido_info_mensagem').val('');
      } else {
          console.log('Error: ' + _error);
          $(".lMsg").html(_error);
      }
    } else {
      	console.log('Null');
        $(".lMsg").html("");
    }
  });

  $(document).on('click', '#btPedidoInformacaoLoja', function (e) {
    e.preventDefault();
    var form = $("#formPedidoInfoLoja");
    form.validate({
      rules: {
        pedido_info_loja_name: {
            required: true,
            notPlaceholder: true
        },
        pedido_info_loja_email: {
            required: true,
            notPlaceholder: true,
            email: true
        },
        pedido_info_loja_contacto: {
            required: true,
            number: true
        },
        pedido_info_loja_areapretendida: {
            required: true,
            number: true
        },
