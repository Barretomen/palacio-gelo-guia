  $(document).on('click', '#btRecrutamento', function (e) {
    var form = $("#formRecrutamento");
    form.validate(
    {
      rules: {
        recrutamento_name: {
            required: true,
            notPlaceholder: true
        },
        recrutamento_email: {
            required: true,
            notPlaceholder: true,
            email: true
        },
        recrutamento_contacto: {
            required: true,
            number: true
        },
        recrutamento_idade: {
            required: true,
            number: true,
            regexAge: /^(1[89]|[2-9][0-9])$/
        },
        recrutamento_sexo: {
            required: false
        },
        uploadCV: {
            required: true
        }
      },
      messages: {
        recrutamento_name: {
            required: _required,
            notPlaceholder: _required,
            minlength:  _min3carac
        },
        recrutamento_email: {
            required: _required,
            email: _valid_email
        },
        recrutamento_contacto: {
            required: _required,
            minlength: _9dig,
            number: _valid_onenumber
        },
        recrutamento_idade: {
            required: _required,
            minlength: _valid_age,
            number: _valid_age
        },
        recrutamento_sexo: {
            required: _required
        },
        uploadCV: {
            required: _required
        }
      }
    });

    var vSex = '';

    if ($("#radio1").is(':checked'))
        vSex = _sex_m;
    else if ($("#radio2").is(':checked'))
        vSex = _sex_f;
    else
        vSex = '-';

    if (form.valid())
    {
      $(".lMsg").html("<center>" + _loading + "<br/><br/><img src='../images/ajax-loader.gif' alt='" + _loading + "' style='width: 128px; height: 15px;' /></center>");

      var fileUpload = $("#uploadBtn").get(0);
      var files = fileUpload.files;

      var data = new FormData();
      for (var i = 0; i < files.length; i++) {
          data.append(files[i].name, files[i]);
      }

      $.ajax({
        url: "https://palaciodogelo.pt/hfileupload.php",
        type: "POST",
        data: data,
        contentType: false,
        processData: false,
        success: function (result) {
          var vSplit = result.split('|');
          //console.log(vSplit[0] + " | " + vSplit[1]);

          if ( vSplit[0] == "OK") {
            var _data = "?id=formRecrutamento&vSubject=Recrutamento&vName=" + $('#recrutamento_name').val() + "&vEmail=" + $('#recrutamento_email').val() + "&vContact=" + $('#recrutamento_contacto').val() + "&vAge=" + $('#recrutamento_idade').val() + "&vSex=" + vSex + "&vArea=" + $('#recrutamento_areaInteresse').val() + "&vFunction=" + $('#recrutamento_funcaoInteresse').val() + "&vAvailability= " + $('#recrutamento_disponibilidade').val() + "&vAvailabilityShifts=" + $('#recrutamento_disponibilidadeTurnos').val() + "&vAcademic=" + $('#recrutamento_formacaoAcademica').val() + "&vProfessional=" + $('#recrutamento_experiencia').val() + "&vLanguages=" + $('#recrutamento_linguas').val() + "&vId_Multilanguage=1&vCV=" + vSplit[1];

            var settings = {
              'data': _data,
              'url': 'https://palaciodogelo.pt/hmail.php' + _data,
              'contentType': 'application/json; charset=utf-8'
            }; //application/x-www-form-urlencoded;charset=UTF-8'

            if (sendEmail(settings) == true) {
              $(".lMsg").html(_success);
              $('#recrutamento_name').val('');
              $('#recrutamento_email').val('');
              $('#recrutamento_contacto').val('');
              $('#recrutamento_idade').val('');
              $("#radio1").prop('checked', false);
              $("#radio2").prop('checked', false);
              $('#recrutamento_areaInteresse').val('');
              $('#recrutamento_funcaoInteresse').val('');
              $('#recrutamento_disponibilidade').val('');
              $('#recrutamento_disponibilidadeTurnos').val('');
              $('#recrutamento_formacaoAcademica').val('');
              $('#recrutamento_experiencia').val('');
              $('#recrutamento_linguas').val('');
              $('#uploadCV').val('');
            } else {
              $(".lMsg").html(_error);
            }
          }
          else {
            $(".lMsg").html(_error);
          }
        },
        error: function (err) {
          $(".lMsg").html(_error);
        }
      });

    } else {
        $(".lMsg").html("");
    }

    e.preventDefault();
  });

  $(document).ready(function () {
    LoadingShop();
    ShowInfo();

    /*if($('[data-shop="giovanni-galli"]').length) {
      $('[data-shop="giovanni-galli"]').css('display', 'block');
      $('[data-shop="giovanni-galli"]').css('align-content', 'center');
      $('[data-shop="giovanni-galli"]').height($('[data-shop="genevcrep"]').height())
    }*/
  });

  function sendEmail(settings) {
    var success = false;

    $.ajax({
      type: "POST",
      contentType: settings.contentType,
      data: settings.data,
      url: settings.url,
      dataType: "html",
      async: false,
      success: function (response) {
        if (response == "ok") {
          success = true;
        } else {
          success = false;
        }
      },
      error: function (jqXHR, status) {
        console.log("Status: " + status);
        console.log("jqXHR: " + jqXHR);
        success = false;
      }
    });
    return success;
  }

  function ppCookies() {
    $('.modalBt')[4].click();
  }

  function LoadingShop() {
    var _hash = document.URL.substr(document.URL.indexOf('#') + 1);

    if (_hash.indexOf("fl-") == 0) {

      var _text = _hash.replace("fl-", "");

      $(".filtrarLojas dt a").html($("[data-category='" + _text + "']").html());
      $(".filtrarLojas dd ul").hide();

      if ( _text == "acessorios")
        $('.filtroLojasdContainer ul li[data-filter="1"]').trigger('click');
      else if ( _text == "bancos")
        $('.filtroLojasdContainer ul li[data-filter="2"]').trigger('click');
      else if ( _text == "casa-e-decoracao")
        $('.filtroLojasdContainer ul li[data-filter="3"]').trigger('click');
      else if ( _text == "cinemas")
        $('.filtroLojasdContainer ul li[data-filter="4"]').trigger('click');
      else if ( _text == "cultura-e-electronica")
        $('.filtroLojasdContainer ul li[data-filter="5"]').trigger('click');
      else if ( _text == "diversos")
        $('.filtroLojasdContainer ul li[data-filter="6"]').trigger('click');
      else if ( _text == "entretenimento")
        $('.filtroLojasdContainer ul li[data-filter="7"]').trigger('click');
      else if ( _text == "estetica-e-saude")
        $('.filtroLojasdContainer ul li[data-filter="8"]').trigger('click');
      else if ( _text == "hipermercado")
        $('.filtroLojasdContainer ul li[data-filter="9"]').trigger('click');
      else if ( _text == "moda")
        $('.filtroLojasdContainer ul li[data-filter="10"]').trigger('click');
      else if ( _text == "moda-desporto")
        $('.filtroLojasdContainer ul li[data-filter="11"]').trigger('click');
      else if ( _text == "moda-infantil")
        $('.filtroLojasdContainer ul li[data-filter="12"]').trigger('click');
      else if ( _text == "restaurantes-e-cafes")
        $('.filtroLojasdContainer ul li[data-filter="13"]').trigger('click');
      else if ( _text == "todas-as-lojas")
        $('.filtroLojasdContainer ul li[data-filter="all"]').trigger('click');
      else
        $('.filtroLojasdContainer ul li[data-filter="all"]').trigger('click');

    } else {
        $("#lojas").find("[data-shop='" + _hash + "']").click();
    }
  }

  var getUrlParameter = function getUrlParameter(sParam) {
    var sPageURL = decodeURIComponent(window.location.search.substring(1)),
      sURLVariables = sPageURL.split('&'),
      sParameterName,
      i;

    for (i = 0; i < sURLVariables.length; i++) {
      sParameterName = sURLVariables[i].split('=');

      if (sParameterName[0] === sParam) {
        return sParameterName[1] === undefined ? true : sParameterName[1];
      }
    }
  };

  function ShowInfo() {
    var _url = window.location.href;
    $("#OtherContents_container").html("");

    if (_url.indexOf("?id=") != -1) {

      var ret = getUrlParameter("id").split(";");

      var vID = 0;
      if (ret[0] != undefined)
          vID = ret[0];

      var vId_Multilanguage = 1;
      if (ret[1] != undefined)
          vId_Multilanguage = ret[1];

      var vURL = 'https://palaciodogelo.pt/hdata.php?pOpc=N&pId_Multilanguage=' + vId_Multilanguage + '&pId=' + vID;

      $.ajax({
        type: 'POST',
        contentType: 'application/json; charset=utf-8',
        dataType: 'html',
        url: vURL,
        success: function (response) {
          $("#OtherContents_container").html(response);
          $('#othercontents').modal('show');
        },
        error: function (jqXHR, textStatus, errorThrown) {
            console.log(textStatus, errorThrown);
        }
      });
    }
  }

</script>
	</body>