<div class="modal fade" id="recrutamento" tabindex="-1" role="dialog" aria-hidden="true" >
	<div class="btCloseContainer clearfix">
		<a class="fa fa-times" aria-hidden="true" data-dismiss="modal" aria-label="Close"></a>
	</div>
	<div class="container clearPadding" role="document">
		<div class="col-lg-12 col-md-12 col-sm-12 col-xs-12 clearPadding titleSectionContainer">
			<h4><span class="linha"></span>Recrutamento</h4>
		</div>

		<div class="col-lg-12 col-md-12 col-sm-12 col-xs-12 clearPadding contentModal">
			<form id="formRecrutamento" class="clearfix marginBottom clearPadding" enctype="multipart/form-data">
				<div class="col-lg-6 col-md-6 col-sm-12 col-xs-12  inputContainer">
					<span>Nome *</span>
					<input type="text" name="recrutamento_name" id="recrutamento_name" value="" placeholder="Nome" minlength="3" class="recrutamentoForm-name" />
				</div>

				<div class="col-lg-6 col-md-6 col-sm-12 col-xs-12  inputContainer">
					<span>Email *</span>
					<input type="email" name="recrutamento_email" id="recrutamento_email" value="" placeholder="Email" class="recrutamentoForm-email" />
				</div>

				<div class="col-lg-6 col-md-6 col-sm-12 col-xs-12  inputContainer">
					<span>Contacto Telefónico *</span>
					<input  name="recrutamento_contacto" id="recrutamento_contacto" value="" placeholder="Contacto Telefónico"  minlength="9" maxlength="9" class="recrutamentoForm-contacto" />
				</div>

				<div class="col-lg-3 col-md-3 col-sm-3 col-xs-6  inputContainer">
					<span>Idade *</span>
					<input  name="recrutamento_idade" id="recrutamento_idade" value="" placeholder="Idade"  minlength="2" maxlength="2" class="recrutamentoForm-idade" />
				</div>

				<div class="col-lg-3 col-md-3 col-sm-3 col-xs-6 inputContainer">
					<span class="clearfix">Sexo *</span>
					<span id="#sexoError"></span>
					<div class="radio">
						<input type="radio" name="recrutamento_sexo" id="radio1" value="option1">
						<label for="radio1">M</label>
					</div>
					<div class="radio">
						<input type="radio" name="recrutamento_sexo" id="radio2" value="option2">
						<label for="radio2">F</label>
					</div>
				</div>

				<div class="col-lg-12 col-md-12 col-sm-12 col-xs-12 clearPadding">
					<span class="col-lg-12 col-md-12 col-sm-12 col-xs-12 inputContainer">Área de interesse</span>
					<div class="col-lg-6 col-md-6 col-sm-12 col-xs-12 clearPadding selectContainer">
						<select class="selectpicker" name="recrutamento_areaInteresse" id="recrutamento_areaInteresse" >
							<option class="disabled" value="Área de interesse">Área de interesse</option>
							<option value="Lojas">Lojas</option>
							<option value="Restauração">Restauração</option>
							<option value="Administração">Administração</option>
						</select>
					</div>

					<div class="col-lg-6 col-md-6 col-sm-12 col-xs-12 clearPadding selectContainer">
						<select class="selectpicker" name="recrutamento_funcaoInteresse" id="recrutamento_funcaoInteresse">
							<option class="disabled" value="Função de interesse">Função de interesse</option>
							<option value="Caixa">Caixa</option>
							<option value="Emprego">Emprego</option>
							<option value="Gerente">Gerente</option>
						</select>
					</div>
				</div>

				<div class="col-lg-12 col-md-12 col-sm-12 col-xs-12 clearPadding">
					<span class="col-lg-12 col-md-12 col-sm-12 col-xs-12 inputContainer">Disponilibidade</span>
					<div class="col-lg-6 col-md-6 col-sm-12 col-xs-12 clearPadding selectContainer">
						<select class="selectpicker" name="recrutamento_disponibilidade" id="recrutamento_disponibilidade">
							<option class="disabled" value="Disponilibidade">Disponilibidade</option>
							<option value="Disponibilidade">Disponibilidade</option>
							<option value="Sem Disponibilidade Imediata">Sem Disponibilidade Imediata</option>
						</select>
					</div>

					<div class="col-lg-6 col-md-6 col-sm-12 col-xs-12 clearPadding selectContainer">
						<select class="selectpicker" name="recrutamento_disponibilidadeTurnos" id="recrutamento_disponibilidadeTurnos">
							<option class="disabled" value="Disponilibidade para Turnos">Disponilibidade para Turnos</option>
							<option value="Disponilibidade para Turnos">Disponilibidade para Turnos</option>
							<option value="Sem Disponibilidade">Sem Disponibilidade</option>
						</select>
					</div>
				</div>

				<div class="col-lg-12 col-md-12 col-sm-12 col-xs-12 clearPadding">
					<span class="col-lg-12 col-md-12 col-sm-12 col-xs-12 inputContainer">Formação Académica</span>
					<div class="col-lg-12 col-md-12 col-sm-12 col-xs-12 clearPadding selectContainer">
						<select class="selectpicker" name="recrutamento_formacaoAcademica" id="recrutamento_formacaoAcademica">
							<option class="disabled" value="Formação Académica">Formação Académica</option>
							<option value="Ensino Básico">Ensino Básico</option>
							<option value="Ensino Secundário">Ensino Secundário</option>
							<option value="Frequência Universitária">Frequência Universitária</option>
							<option value="Licenciatura">Licenciatura</option>
						</select>
					</div>
				</div>

				<div class="col-lg-6 col-md-6 col-sm-12 col-xs-12  inputContainer">
					<span class="clearfix">Experiência profissional</span>
					<textarea placeholder="Experiência profissional" name="recrutamento_experiencia" id="recrutamento_experiencia" rows="5" ></textarea>
				</div>

				<div class="col-lg-6 col-md-6 col-sm-12 col-xs-12  inputContainer">
					<span class="clearfix">Línguas</span>
					<textarea placeholder="Línguas" rows="5" name="recrutamento_linguas" id="recrutamento_linguas" ></textarea>
				</div>

				<div class="col-lg-12 col-md-12 col-sm-12 col-xs-12  inputContainer">
					<span class="clearfix">Anexar CV *</span>
					<div class="uploadContainer clearfix">
						<div class="uploadCv">
							<span>Upload</span>
							<input id="uploadBtn" type="file" class="upload" accept=".pdf" onchange="javascript:changUpl(this)"/>
						</div>
						<div class="disabledContainer">
							<span>&nbsp;</span>
							<input id="uploadCV" name="uploadCV" placeholder="Anexar CV" />
						</div>
					</div>
				</div>

				<div class="col-lg-12 col-md-12 col-sm-12 col-xs-12 inputContainer">
						<button id="btRecrutamento">Enviar</button>
						<br />
						<div class="ajax-loading"></div>
						<div class="lMsg"></div>
				</div>
				<script>
						function changUpl(e) {
							document.getElementById("uploadCV").value = e.value;
						}
				</script>
			</form>
			<p class="col-lg-12 col-md-12 col-sm-12 col-xs-12 small inputContainer">
					*O seu CV só pode ser enviado com extensão .pdf					<br>
					O seu CV ficará na base de dados que é disponibilizada aos lojistas, quando os mesmos a solicitam.					<br>
					O recrutamento é feito pelos lojistas directamente.					<br>
					Poderá ainda inscrever-se directamente nas lojas que têm o indicativo de "colaborador precisa-se" na montra.			</p>
		</div>
	</div>
</div>

